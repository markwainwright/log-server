{
  "name": "log-server",
  "version": "1.0.0",
  "description": "A Node.js HTTP, HTTPS, or TCP server that logs incoming requests in a readable way, and allows response behaviour to be customized",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "start": "npm run build && node dist",
    "start:watch": "NODE_OPTIONS=\"--loader ts-node/esm --no-warnings=ExperimentalWarning\" nodemon -q --ext ts src/index.ts",
    "test": "tap --reporter terse --passes --show-full-coverage --typecheck",
    "test:watch": "tap repl w on --passes"
  },
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@tsconfig/node20": "^20.1.2",
    "@types/node": "^20.11.17",
    "@types/tap": "^15.0.11",
    "nodemon": "^3.0.3",
    "tap": "^18.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "tap": {
    "coverage-map": "./test-map.js"
  }
}
