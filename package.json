{
  "name": "log-server",
  "version": "1.0.0",
  "description": "A simple Node.js HTTP server that logs incoming connections and requests in a readable way.",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "start": "npm run build && node dist",
    "start:watch": "nodemon -q --ext ts --exec \"ts-node --esm src/index.ts\"",
    "test": "tap --reporter terse --passes --show-full-coverage --typecheck",
    "test:watch": "tap repl w on --passes"
  },
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@tsconfig/node20": "^20.1.2",
    "@types/node": "^20.8.10",
    "@types/tap": "^15.0.10",
    "nodemon": "^3.0.1",
    "tap": "^18.5.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "tap": {
    "coverage-map": "./test-map.js"
  }
}
